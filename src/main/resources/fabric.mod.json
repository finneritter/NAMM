{
	"schemaVersion": 1,
	"id": "namm",
	"version": "${version}",
	"name": "NAMM",
	"description": "Minecraft PvP utility mod with macros, target HUD, and hacked-client-style UI",
	"authors": [
		"finnritter"
	],
	"contact": {},
	"license": "MIT",
	"icon": "assets/namm/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			"com.namm.NammMod"
		],
		"modmenu": [
			"com.namm.NammModMenuIntegration"
		]
	},
	"mixins": [
		{
			"config": "namm.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.2",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	},
	"suggests": {
		"modmenu": "*"
	}
}
